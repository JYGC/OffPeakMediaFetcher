@using System.Text.Json
@using MediaManager.Services

@inject IChannelMetadataServices ChannelMetadataServices

<MudTable
                T="OPMF.Entities.ChannelMetadata"
                Items="_results"
                Breakpoint="Breakpoint.Sm"
                Loading="@_loading"
                Virtualize="true"
                FixedHeader="true"
                LoadingProgressColor="Color.Info"
                Height="80vh">
    <ToolBarContent>
        <MudText Typo="Typo.subtitle1">Find Videos from Database</MudText>
        <MudSpacer />
        <MudTextField
                      @bind-Value="_videoTitle"
                      Placeholder="Video title"
                      Variant="Variant.Text"></MudTextField>
        <MudTextField @bind-Value="_channelName"
                      Placeholder="Channel name"
                      Variant="Variant.Text"></MudTextField>
        <MudButton Variant="Variant.Outlined" OnClick="Submit">Find</MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Status</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Title</MudTh>
        <MudTh>PublishedAt</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Status">@context.Metadata.Status</MudTd>
        <MudTd DataLabel="Name">@context.Channel.Name</MudTd>
        <MudTd DataLabel="Title">@context.Metadata.Title</MudTd>
        <MudTd DataLabel="PublishedAt">@context.Metadata.PublishedAt</MudTd>
    </RowTemplate>
</MudTable>

    @code {
    private const int pageSize = 10000;

    private string _videoTitle = "";
    private string _channelName = "";

    private bool _loading = false;

    private List<OPMF.Entities.ChannelMetadata> _results = new();
    private int _skip = 0;

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_videoTitle) && string.IsNullOrWhiteSpace(_channelName))
        {
            return;
        }

        _results = new();
        _skip = 0;

        List<OPMF.Entities.ChannelMetadata>? resultsChuck = null;

        _loading = true;
        await Task.Run(() =>
        {
            do
            {
                resultsChuck = string.IsNullOrWhiteSpace(_channelName)
                ? ChannelMetadataServices.GetByTitleContainingWord(_videoTitle, _skip, pageSize)
                : ChannelMetadataServices.GetByChannelAndTitleContainingWord(_channelName, _videoTitle,
                    _skip, pageSize);
                _results.AddRange(resultsChuck);
                _skip += pageSize;
            }
            while (resultsChuck != null && resultsChuck.Count() == pageSize);
        });

        _loading = false;
    }
}
