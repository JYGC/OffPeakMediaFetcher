@using OPMF.Entities
@using MediaManagerUI.Modules.VideoBrowser

@inject IDialogService _dialog

<MudTable T="OPMF.Entities.ChannelMetadata"
          Items="_getVideoTableModule?.Results"
          Breakpoint="Breakpoint.Sm"
          Loading="@(_getVideoTableModule?.IsLoading ?? false)"
          Virtualize="true"
          FixedHeader="true"
          LoadingProgressColor="Color.Info"
          Height="80vh">
    <ToolBarContent>
        @if (TableToolBarContent != null)
        {
            @TableToolBarContent
        }
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Status</MudTh>
        <MudTh>Channel</MudTh>
        <MudTh>Title</MudTh>
        <MudTh>PublishedAt</MudTh>
    </HeaderContent>
    <LoadingContent>
        <MudText>Loading...</MudText>
    </LoadingContent>
    <RowTemplate>
        <MudTd DataLabel="Status">
            @foreach (var status in _metadataStatus)
            {
                @if (_getVideoTableModule != null)
                {
                    <MudButton Variant="@ComputeStatusButtonVariant(status, context.Metadata)"
                               Color="@((context.Metadata.Status == status) ? Color.Secondary : Color.Default)"
                               OnClick="() => _getVideoTableModule.ScheduleMetadataStatusUpdate(status, context.Metadata)"
                               Disabled="_getVideoTableModule.UnselectableMetadataStatuses.Contains(status)"
                               Size="Size.Small"
                               Class="ml-0 mr-0 pl-2 pr-2">
                        @status
                    </MudButton>
                }
            }
        </MudTd>
        <MudTd DataLabel="Channel">@context.Channel.Name</MudTd>
        <MudTd DataLabel="Title">
            <MudButton OnClick="@(() => OpenVideoDetailDialog())">@context.Metadata.Title</MudButton>
        </MudTd>
        <MudTd DataLabel="PublishedAt">@context.Metadata.PublishedAt</MudTd>
    </RowTemplate>
</MudTable>

    @code {
    private IGetVideoTableModule? _getVideoTableModule;
    [Parameter]
    public IGetVideoTableModule? GetVideoTableModule
    {
        get => _getVideoTableModule;
        set
        {
            if (_getVideoTableModule == value)
            {
                return;
            }
            _getVideoTableModule = value;
            GetVideoTableModuleChanged.InvokeAsync(value);
        }
    }
    [Parameter]
    public EventCallback<IGetVideoTableModule> GetVideoTableModuleChanged { get; set; }

    [Parameter]
    public RenderFragment? TableToolBarContent { get; set; }

    private MetadataStatus[] _metadataStatus = Enum.GetValues(typeof(MetadataStatus)).Cast<MetadataStatus>().ToArray();

    protected override void OnParametersSet()
    {
        if (_getVideoTableModule == null)
        {
            throw new Exception("Please set GetResults to a method");
        }
        base.OnParametersSet();
    }

    private Task OpenVideoDetailDialog()
    {
        return _dialog.ShowAsync<_VideoDetails>(
            "Video details",
            new DialogParameters<_VideoDetails>
            {
                {
                    x => x.Arg, "Test"
                }
            },
            new DialogOptions
            {
                FullScreen = true,
                CloseButton = true
            });
    }

    private Variant ComputeStatusButtonVariant(MetadataStatus status, IMetadata metadata) =>
        (_getVideoTableModule != null && !_getVideoTableModule.UnselectableMetadataStatuses.Contains(status)) ? Variant.Filled
            : (metadata.Status == status) ? Variant.Outlined
            : Variant.Text;
}
